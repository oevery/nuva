{
  "name": "nuva",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Nuxt full-stack scaffold with a reusable core layer and business template.",
  "author": "",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "dev": "pnpm --filter nuva-app dev",
    "build": "pnpm --filter nuva-app build",
    "generate": "pnpm --filter nuva-app generate",
    "preview": "pnpm --filter nuva-app preview",
    "prepare": "pnpm --filter @oevery/nuva prepare && pnpm --filter nuva-app prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm --filter @oevery/nuva typecheck && pnpm --filter nuva-app typecheck"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "alova": "^3.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-format": "^2.0.1",
    "nuxt": "^4.4.6",
    "typescript": "^6.0.3"
  }
}
