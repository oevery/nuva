{
  "name": "nuva",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "description": "Nuxt full-stack scaffold with a reusable core layer and business template.",
  "author": "",
  "license": "MIT",
  "keywords": [],
  "scripts": {
    "core:dev": "pnpm --filter @oevery/nuva run dev",
    "core:build": "pnpm --filter @oevery/nuva run build",
    "core:check": "pnpm --filter @oevery/nuva run check",
    "core:prepare": "pnpm --filter @oevery/nuva run prepare",
    "core:test": "pnpm --filter @oevery/nuva run test",
    "core:typecheck": "pnpm --filter @oevery/nuva run typecheck",
    "docs:dev": "pnpm --filter nuva-docs run dev",
    "docs:build": "pnpm --filter nuva-docs run build",
    "docs:generate": "pnpm --filter nuva-docs run generate",
    "docs:prepare": "pnpm --filter nuva-docs run prepare",
    "docs:preview": "pnpm --filter nuva-docs run preview",
    "docs:typecheck": "pnpm --filter nuva-docs run typecheck",
    "template:dev": "pnpm --filter nuva-app run dev",
    "template:build": "pnpm --filter nuva-app run build",
    "template:generate": "pnpm --filter nuva-app run generate",
    "template:prepare": "pnpm --filter nuva-app run prepare",
    "template:preview": "pnpm --filter nuva-app run preview",
    "template:typecheck": "pnpm --filter nuva-app run typecheck",
    "check": "pnpm lint && pnpm typecheck",
    "prepare": "pnpm -r prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release:core": "pnpm --filter @oevery/nuva publish",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "typescript": "catalog:"
  }
}
