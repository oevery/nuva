{
  "name": "@oevery/nuva",
  "type": "module",
  "version": "0.0.0",
  "private": false,
  "description": "Reusable Nuxt full-stack layer for Nuva applications.",
  "license": "MIT",
  "exports": {
    ".": "./nuxt.config.ts",
    "./base": "./modules/nuva/module.ts",
    "./nuxt.config": "./nuxt.config.ts",
    "./auth": "./modules/auth/module.ts",
    "./auth/adapter": "./modules/auth/runtime/adapters/registry.ts",
    "./auth/access-menu": "./modules/auth/runtime/utils/access-menu.ts",
    "./auth/permission": "./modules/auth/runtime/utils/permission.ts",
    "./auth/server-adapter": "./modules/auth/runtime/adapters/server-registry.ts",
    "./auth/state": "./modules/auth/runtime/internal/clearAuthState.ts",
    "./auth/token": "./modules/auth/runtime/composables/useTokenAuthClient.ts",
    "./better-auth": "./modules/better-auth/module.ts",
    "./better-auth/client": "./modules/better-auth/runtime/composables/useBetterAuthClient.ts",
    "./better-auth/server-adapter": "./modules/better-auth/runtime/server-adapter.ts",
    "./config": "./config/index.ts",
    "./nuva-config": "./config/index.ts",
    "./http": "./http/index.ts",
    "./server/utils/config": "./server/utils/config.ts",
    "./server/utils/permission": "./server/utils/permission.ts",
    "./server/*": "./server/*",
    "./app/*": "./app/*"
  },
  "files": [
    "app",
    "config",
    "http",
    "modules",
    "nuxt.config.ts",
    "server",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "pnpm prepare",
    "build": "pnpm check",
    "check": "pnpm prepare && pnpm typecheck",
    "prepare": "nuxt prepare",
    "prepack": "pnpm check",
    "prepublishOnly": "pnpm check",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "pnpm prepare && vitest run --project nuxt-runtime",
    "test:runtime": "pnpm prepare && vitest run tests/runtime",
    "test:e2e": "pnpm prepare && pnpm exec node ./tests/clean-fixtures.mjs && vitest run --project e2e-node",
    "test:watch": "pnpm prepare && vitest --project nuxt-runtime",
    "test:coverage": "pnpm prepare && vitest run --project nuxt-runtime --coverage",
    "typecheck": "nuxt typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "alova": ">=3.0.0",
    "better-auth": ">=1.6.0",
    "nuxt": ">=4.0.0",
    "valibot": ">=1.4.1"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  },
  "dependencies": {
    "@nuxt/icon": "catalog:",
    "@nuxt/kit": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "defu": "catalog:",
    "ohash": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@nuxt/test-utils": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vue/test-utils": "catalog:",
    "alova": "catalog:",
    "better-auth": "catalog:",
    "happy-dom": "catalog:",
    "msw": "catalog:",
    "nuxt": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
