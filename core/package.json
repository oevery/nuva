{
  "name": "@oevery/nuva",
  "type": "module",
  "version": "0.0.0",
  "private": false,
  "description": "Reusable Nuxt full-stack layer for Nuva applications.",
  "license": "MIT",
  "exports": {
    ".": "./nuxt.config.ts",
    "./base": "./modules/nuva/module.ts",
    "./nuxt.config": "./nuxt.config.ts",
    "./auth": "./modules/auth/module.ts",
    "./config": "./config/index.ts",
    "./nuva-config": "./config/index.ts",
    "./http": "./http/index.ts",
    "./server/utils/config": "./server/utils/config.ts",
    "./server/utils/permission": "./server/utils/permission.ts",
    "./server/*": "./server/*",
    "./app/*": "./app/*"
  },
  "files": [
    "app",
    "config",
    "http",
    "modules",
    "nuxt.config.ts",
    "server",
    "tsconfig.json"
  ],
  "scripts": {
    "check": "pnpm prepare && pnpm typecheck",
    "prepare": "nuxt prepare",
    "prepack": "pnpm check",
    "prepublishOnly": "pnpm check",
    "typecheck": "nuxt typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "alova": ">=3.0.0",
    "nuxt": ">=4.0.0",
    "valibot": ">=1.4.1"
  },
  "dependencies": {
    "@nuxt/icon": "catalog:",
    "@nuxt/kit": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "better-auth": "catalog:",
    "defu": "catalog:",
    "ohash": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "alova": "catalog:",
    "nuxt": "catalog:",
    "typescript": "catalog:"
  }
}
