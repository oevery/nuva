{
  "name": "@oevery/nuva",
  "type": "module",
  "version": "0.0.0",
  "private": false,
  "description": "Reusable Nuxt full-stack layer for Nuva applications.",
  "license": "MIT",
  "exports": {
    ".": "./nuxt.config.ts",
    "./nuxt.config": "./nuxt.config.ts",
    "./auth": "./modules/auth/module.ts",
    "./config": "./config/index.ts",
    "./http": "./http/index.ts",
    "./app/*": "./app/*"
  },
  "files": [
    "app",
    "config",
    "http",
    "modules",
    "nuxt.config.ts",
    "tsconfig.json"
  ],
  "scripts": {
    "check": "pnpm prepare && pnpm typecheck",
    "prepare": "nuxt prepare",
    "prepack": "pnpm check",
    "prepublishOnly": "pnpm check",
    "typecheck": "nuxt typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "alova": ">=3.0.0",
    "nuxt": ">=4.0.0"
  },
  "dependencies": {
    "@nuxt/icon": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@vueuse/nuxt": "catalog:",
    "better-auth": "catalog:",
    "defu": "catalog:",
    "ohash": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@nuxt/kit": "catalog:",
    "@types/node": "catalog:",
    "alova": "catalog:",
    "nuxt": "catalog:",
    "typescript": "catalog:"
  }
}
