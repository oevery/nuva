{
  "name": "@oevery/nuva",
  "type": "module",
  "version": "0.0.0",
  "private": false,
  "description": "Reusable Nuxt full-stack layer for Nuva applications.",
  "license": "MIT",
  "exports": {
    ".": "./nuxt.config.ts",
    "./nuxt.config": "./nuxt.config.ts",
    "./app/types/config": "./app/types/config.ts",
    "./app/*": "./app/*"
  },
  "files": [
    "app",
    "nuxt.config.ts",
    "tailwind.config.js",
    "tsconfig.json"
  ],
  "scripts": {
    "check": "pnpm prepare && pnpm typecheck",
    "prepare": "nuxt prepare",
    "prepack": "pnpm check",
    "prepublishOnly": "pnpm check",
    "typecheck": "nuxt typecheck"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@nuxtjs/tailwindcss": ">=6.0.0",
    "alova": ">=3.0.0",
    "nuxt": ">=4.0.0"
  },
  "dependencies": {
    "ohash": "^2.0.11"
  }
}
